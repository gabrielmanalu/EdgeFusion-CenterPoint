# Python
__pycache__/
*.pyc
*.egg-info/
dist/
build/

# Checkpoints & large data
*.pth
*.pkl
*.bin
*.onnx
*.engine
*.trt
data/

# MLflow
mlruns/

# Results (tracked separately)
baseline/results/*.json
# compression/results/: large checkpoints (.pth/.pt) not tracked, see README
# Checkpoints section for Google Drive links. pareto/ (charts + summary,
# small, embedded in compression/README.md) IS tracked — must use `/*` + `!`
# rather than a bare directory pattern, or git won't descend to negate it.
compression/results/*
!compression/results/pareto/
deployment/benchmarks/results/

# C++ build artefacts
deployment/build/
*.o
*.a
*.so

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.idea/